# ============================================================
# Station identity — fill these in for your installation
# ============================================================

# Human-readable description of the station location
WEEWX_LOCATION="My Weather Station"

# Decimal degrees. Negative for southern hemisphere.
WEEWX_LATITUDE=0.000000
# Decimal degrees. Negative for western hemisphere.
WEEWX_LONGITUDE=0.000000

# Altitude with unit, e.g. "550, foot" or "168, meter"
WEEWX_ALTITUDE="0, foot"

# LAN IP address of the Ecowitt gateway
ECOWITT_IP=192.168.1.100

# Weather Underground station ID (e.g. KNHKEENE82)
# Find it at https://www.wunderground.com/member/devices
WU_STATION_ID=KXXXXXXXX00

# ============================================================
# Credentials — never commit this file
# ============================================================

# Weather Underground station key (not your account password)
# Find it at https://www.wunderground.com/member/devices
WU_PASSWORD=your_wunderground_station_key

# Cloudflare API token — create at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Cloudflare account ID — find at https://dash.cloudflare.com (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Cloudflare Pages project name
CLOUDFLARE_PROJECT_NAME=your-pages-project-name

# rclone remote:bucket for backup sync (e.g. cloudflare:my-weather-backups)
# Configure the remote first with: rclone config
RCLONE_REMOTE=cloudflare:your-r2-bucket-name

# Healthchecks.io check UUID — find at https://healthchecks.io
HEALTHCHECK_UUID=your_healthcheck_uuid
