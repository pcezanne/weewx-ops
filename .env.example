# Cloudflare API token — create at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Cloudflare account ID — find at https://dash.cloudflare.com (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Healthchecks.io check UUID — find at https://healthchecks.io
HEALTHCHECK_UUID=your_healthcheck_uuid

# Weather Underground station key — find at https://www.wunderground.com/member/devices
WU_PASSWORD=your_wunderground_password
